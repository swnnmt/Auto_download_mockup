# main đã tạo và push khung cùng các file build
# git branch dev  # tạo nhánh dev 

# start
# git checkout main     #chuyển sang nhánh main
# git pull origin main  # lấy tất cả code ở main hiện tại
# git checkout dev      # sang nhánh dev
# git merge main        # lấy code mới nhất ở main

# tạo nhánh feature
# git checkout -b feature/ten-tinh-nang  tạo nhánh cho chức năng

# Code xong
# git add .
# git commit -m "Thêm tính năng A"
# git push origin feature/ten-tinh-nang

# tạo Pull Request (merge vào dev) # bấm pull request trên git

# Test ( ko cần tạo nhánh tránh rối)
# git checkout dev
# git pull origin dev
# Test và báo lỗi trên Pull Request

# Dev fix bug → push lại branch feature

# Done → merge Pull Request vào dev

# Release
# git checkout main
# git pull origin main
# git merge dev
# git push origin main